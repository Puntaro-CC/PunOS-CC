-- PunOS Updater
-- Incremental updates (gated by version.json commits), rollback, updater-safety guard

os.pullEvent = os.pullEventRaw

local UI = dofile("/os/loadTheme.lua")
local w, h = term.getSize()

local REPO_RAW       = "https://raw.githubusercontent.com/Puntaro-CC/PunOS-CC/"
local RAW_MAIN       = REPO_RAW .. "main/"
local API_BASE       = "https://api.github.com/repos/Puntaro-CC/PunOS-CC/"
local API_VER_LATEST = API_BASE .. "commits?path=version.json&per_page=1"
local API_VER_HIST   = API_BASE .. "commits?path=version.json&per_page=20"
local API_COMPARE    = API_BASE .. "compare/"
local LOCAL_VER      = "/.punos_version"
local LOCAL_SHA      = "/.punos_sha"
local LOCAL_CACHE    = "/.punos_files_cache"

-- .updater is NEVER replaced by the updater itself, forward or backward.
-- Use the installer to update the updater.
local UPDATER_LOCAL_PATH = "/os/.updater"

-- ---- Helpers ----------------------------------------------------------------

local function drawHeader()
    paintutils.drawFilledBox(1, 1, w, 2, UI.border)
    term.setCursorPos(2, 1)
    term.setTextColor(UI.primary)
    term.write("PunOS")
    term.setCursorPos(2, 2)
    term.setTextColor(UI.subtext)
    term.write("Update Manager")
    local info = "ID:" .. os.getComputerID()
    term.setCursorPos(w - #info - 1, 2)
    term.setTextColor(UI.subtext)
    term.write(info)
end

local function drawTabs(active)
    paintutils.drawFilledBox(1, 3, w, 3, UI.border)
    local tabs   = { " Updates ", " History " }
    local bounds = {}
    local x      = 2
    for i, label in ipairs(tabs) do
        local x2 = x + #label - 1
        if i == active then
            paintutils.drawFilledBox(x, 3, x2, 3, UI.primary)
            term.setCursorPos(x, 3)
            term.setTextColor(UI.background)
        else
            paintutils.drawFilledBox(x, 3, x2, 3, UI.border)
            term.setCursorPos(x, 3)
            term.setTextColor(UI.subtext)
        end
        term.write(label)
        bounds[i] = { x, x2 }
        x = x2 + 2
    end
    return bounds
end

local function clearBody()
    for y = 4, h do
        term.setCursorPos(1, y)
        term.setBackgroundColor(UI.background)
        term.clearLine()
    end
end

local function status(y, msg, col)
    term.setCursorPos(2, y)
    term.setBackgroundColor(UI.background)
    term.setTextColor(col or UI.subtext)
    term.clearLine()
    term.write(msg)
end

local function readLocalVersion()
    if not fs.exists(LOCAL_VER) then return "unknown" end
    local f = fs.open(LOCAL_VER, "r")
    local v = f.readAll():gsub("%s+", "")
    f.close()
    return v
end

local function saveLocalVersion(v)
    local f = fs.open(LOCAL_VER, "w")
    f.write(v)
    f.close()
end

local function readLocalSHA()
    if not fs.exists(LOCAL_SHA) then return nil end
    local f = fs.open(LOCAL_SHA, "r")
    local s = f.readAll():gsub("%s+", "")
    f.close()
    return s ~= "" and s or nil
end

local function saveLocalSHA(s)
    local f = fs.open(LOCAL_SHA, "w")
    f.write(s)
    f.close()
end

local function httpGet(url)
    local ok, res = pcall(http.get, url)
    if not ok or not res then return nil end
    local body = res.readAll()
    res.close()
    return body
end

local function httpGetBinary(url)
    local ok, res = pcall(http.get, url, nil, true)
    if not ok or not res then return nil end
    local body = res.readAll()
    res.close()
    return body
end

local function jsonStr(body, key)
    return body:match('"' .. key .. '"%s*:%s*"([^"]*)"')
end

local function parseFiles(json)
    local files = {}
    for repoPath, localPath in json:gmatch('"([^"]+)"%s*:%s*"([^"]+)"') do
        if repoPath ~= "files" then
            table.insert(files, { repoPath, localPath })
        end
    end
    return files
end

local function parseFilesAsMap(json)
    local map = {}
    for repoPath, localPath in json:gmatch('"([^"]+)"%s*:%s*"([^"]+)"') do
        if repoPath ~= "files" then
            map[repoPath] = localPath
        end
    end
    return map
end

local function fetchVersionAtSHA(sha)
    local body = httpGet(REPO_RAW .. sha .. "/version.json")
    if not body then return nil end
    return jsonStr(body, "version")
end

-- ---- Confirm dialog ---------------------------------------------------------
-- Returns true if confirmed, false if cancelled.

local function confirmDialog(lines, yesLabel, noLabel)
    yesLabel = yesLabel or " Yes, proceed "
    noLabel  = noLabel  or " Cancel "

    clearBody()

    local midY   = math.floor(h / 2)
    local startY = midY - math.floor(#lines / 2)

    for i, line in ipairs(lines) do
        local col = (i == 1) and UI.error or UI.text
        term.setCursorPos(math.floor((w - #line) / 2), startY + i - 1)
        term.setBackgroundColor(UI.background)
        term.setTextColor(col)
        term.write(line)
    end

    local btnY = startY + #lines + 2
    local yesX = math.floor(w / 2) - #yesLabel - 1
    local noX  = math.floor(w / 2) + 2

    paintutils.drawFilledBox(yesX, btnY, yesX + #yesLabel - 1, btnY, UI.error)
    term.setCursorPos(yesX, btnY)
    term.setTextColor(UI.background)
    term.write(yesLabel)

    paintutils.drawFilledBox(noX, btnY, noX + #noLabel - 1, btnY, UI.primary)
    term.setCursorPos(noX, btnY)
    term.setTextColor(UI.background)
    term.write(noLabel)

    while true do
        local e, p1, p2, p3 = os.pullEvent()
        if e == "mouse_click" then
            local mx, my = p2, p3
            if my == btnY then
                if mx >= yesX and mx <= yesX + #yesLabel - 1 then return true
                elseif mx >= noX and mx <= noX + #noLabel - 1 then return false
                end
            end
        elseif e == "key" then
            if p1 == keys.enter or p1 == keys.y then return true
            elseif p1 == keys.n or p1 == keys.backspace or p1 == keys.escape then return false
            end
        end
    end
end

-- ---- Fetch initial data -----------------------------------------------------

term.setBackgroundColor(UI.background)
term.clear()
drawHeader()
drawTabs(1)
status(5, "Checking for updates...", UI.subtext)
status(6, "Connecting to GitHub...", UI.subtext)

-- Fetch the latest commit that touched version.json specifically.
-- Random file saves in GitHub won't trigger updates; only a version bump will.
local verCommitBody = httpGet(API_VER_LATEST)
if not verCommitBody then
    clearBody()
    status(5, "Could not reach GitHub.", UI.error)
    status(6, "Check HTTP is enabled in CC config.", UI.subtext)
    status(8, "Press any key to return.", UI.subtext)
    os.pullEvent("key")
    shell.run(".menu")
    return
end

local ok, verCommits = pcall(textutils.unserialiseJSON, verCommitBody)
if not ok or not verCommits or not verCommits[1] then
    clearBody()
    status(5, "Could not parse commit data.", UI.error)
    status(7, "Press any key to return.", UI.subtext)
    os.pullEvent("key")
    shell.run(".menu")
    return
end

local latestSHA  = verCommits[1].sha
local patchNotes = "No patch notes available."
if verCommits[1].commit and verCommits[1].commit.message then
    patchNotes = verCommits[1].commit.message
        :gsub("\\n", "\n"):gsub("\\t", "  "):gsub('\\"', '"')
end

-- files.json is required to update. If it can't be fetched we stay in the
-- updater but disable the Update button rather than booting back to .menu.
status(6, "Fetching file list...", UI.subtext)
local filesBody = httpGet(RAW_MAIN .. "files.json")
local filesOk   = (filesBody ~= nil)
local FILES     = filesOk and parseFiles(filesBody) or {}

local localVersion  = readLocalVersion()
local localSHA      = readLocalSHA()
local remoteVersion = jsonStr(httpGet(RAW_MAIN .. "version.json") or "", "version") or "?"
local upToDate      = (latestSHA ~= nil and latestSHA == localSHA)

-- ---- Tab state --------------------------------------------------------------

local activeTab = 1
local tabBounds = {}

-- ---- Updates Tab ------------------------------------------------------------

local notesY   = 8
local notesEnd = h - 4
local visLines = notesEnd - notesY + 1

local noteLines = {}
for line in (patchNotes .. "\n"):gmatch("([^\n]*)\n") do
    if #line == 0 then
        table.insert(noteLines, "")
    else
        while #line > 0 do
            if #line <= w - 3 then
                table.insert(noteLines, line)
                break
            else
                local chunk = line:sub(1, w - 3)
                local space = chunk:match(".*()%s") or w - 3
                table.insert(noteLines, line:sub(1, space))
                line = line:sub(space + 1)
            end
        end
    end
end

local scrollOff   = 0
local updateLabel = upToDate and " Re-install " or " Update Now "
local backLabel   = " Back "
local ux          = math.floor(w / 2) - #updateLabel - 1
local bx          = math.floor(w / 2) + 2

local function drawNotes()
    for y = notesY, notesEnd do
        term.setCursorPos(1, y)
        term.setBackgroundColor(UI.background)
        term.clearLine()
    end
    for i = 1, visLines do
        local lineIdx = i + scrollOff
        if noteLines[lineIdx] then
            term.setCursorPos(2, notesY + i - 1)
            term.setTextColor(UI.text)
            term.write(noteLines[lineIdx])
        end
    end
    if scrollOff > 0 then
        term.setCursorPos(w - 5, notesY)
        term.setTextColor(UI.subtext)
        term.write("[^ up]")
    end
    if scrollOff + visLines < #noteLines then
        term.setCursorPos(w - 7, notesEnd)
        term.setTextColor(UI.subtext)
        term.write("[v more]")
    end
end

local function drawButtons()
    -- Update button: grayed out entirely if files.json unavailable
    local updateActive = filesOk
    paintutils.drawFilledBox(ux, h - 1, ux + #updateLabel - 1, h - 1,
        (not updateActive or upToDate) and UI.border or UI.primary)
    term.setCursorPos(ux, h - 1)
    term.setTextColor(
        (not updateActive) and UI.subtext or
        upToDate           and UI.subtext or
        UI.background)
    term.write(updateLabel)

    paintutils.drawFilledBox(bx, h - 1, bx + #backLabel - 1, h - 1, UI.border)
    term.setCursorPos(bx, h - 1)
    term.setTextColor(UI.text)
    term.write(backLabel)
end

local function drawUpdatesTab()
    clearBody()

    term.setCursorPos(2, 5)
    term.setTextColor(UI.subtext)
    term.write("Installed:  ")
    term.setTextColor(UI.text)
    term.write(localVersion)

    term.setCursorPos(2, 6)
    term.setTextColor(UI.subtext)
    term.write("Available:  ")
    term.setTextColor(upToDate and UI.success or UI.primary)
    if filesOk then
        term.write(remoteVersion .. " (" .. #FILES .. " files)")
    else
        term.write(remoteVersion)
        term.setTextColor(UI.error)
        term.setCursorPos(2, 7)
        term.write("files.json unavailable — updates disabled")
    end

    paintutils.drawFilledBox(1, notesY - 1, w, notesY - 1, UI.border)
    term.setCursorPos(2, notesY - 1)
    term.setTextColor(UI.primary)
    term.write("Patch Notes:")

    drawNotes()

    paintutils.drawFilledBox(1, h - 2, w, h - 2, UI.border)
    drawButtons()

    term.setCursorPos(2, h)
    term.setBackgroundColor(UI.background)
    term.setTextColor(UI.subtext)
    term.write("Scroll: Notes  |  Backspace: Back")
end

-- ---- History Tab ------------------------------------------------------------

local histEntries  = nil
local histScroll   = 0
local histSelected = nil
local HIST_START   = 5
local HIST_END     = h - 3
local HIST_VIS     = HIST_END - HIST_START + 1
local HIST_INSTALL = " Install This Version "

local function loadHistory()
    clearBody()
    status(5, "Loading version history...", UI.subtext)

    local body = httpGet(API_VER_HIST)
    if not body then
        status(5, "Could not fetch history.", UI.error)
        sleep(1.5)
        return false
    end

    local ok2, data = pcall(textutils.unserialiseJSON, body)
    if not ok2 or not data then
        status(5, "Could not parse history.", UI.error)
        sleep(1.5)
        return false
    end

    local raw = {}
    for _, entry in ipairs(data) do
        local sha  = entry.sha
        local msg  = ""
        local date = ""
        if entry.commit then
            msg  = (entry.commit.message or ""):match("^([^\n]+)") or ""
            date = (entry.commit.author and entry.commit.author.date or ""):sub(1, 10)
        end
        table.insert(raw, { sha = sha, msg = msg, date = date })
    end

    -- Fetch version.json at each SHA for human-readable version numbers.
    -- One HTTP request per entry; progress bar shown while loading.
    status(5, "Fetching version numbers...", UI.subtext)
    local barW = w - 4
    local barX = 3
    local barY = 7
    paintutils.drawFilledBox(barX, barY, barX + barW - 1, barY, UI.border)

    histEntries = {}
    for i, entry in ipairs(raw) do
        local ver = fetchVersionAtSHA(entry.sha) or ("?" .. entry.sha:sub(1, 7))
        table.insert(histEntries, {
            sha     = entry.sha,
            version = ver,
            msg     = entry.msg,
            date    = entry.date,
        })

        local filled = math.floor(barW * (i / #raw))
        if filled > 0 then
            paintutils.drawFilledBox(barX, barY, barX + filled - 1, barY, UI.primary)
        end
        local pct = math.floor(100 * i / #raw) .. "%"
        term.setCursorPos(math.floor((w - #pct) / 2), barY - 1)
        term.setBackgroundColor(UI.background)
        term.setTextColor(UI.primary)
        term.write(pct)
    end

    return true
end

local function drawHistoryTab()
    clearBody()

    if not histEntries then
        if not loadHistory() then return end
    end

    paintutils.drawFilledBox(1, HIST_START - 1, w, HIST_START - 1, UI.border)
    term.setCursorPos(2, HIST_START - 1)
    term.setTextColor(UI.primary)
    term.write("Version History")

    for i = 1, HIST_VIS do
        local idx   = i + histScroll
        local entry = histEntries and histEntries[idx]
        local y     = HIST_START + i - 1

        term.setCursorPos(1, y)
        term.setBackgroundColor(UI.background)
        term.clearLine()

        if entry then
            local isInstalled = (entry.sha == localSHA)
            local isSel       = (histSelected == idx)

            if isSel then
                paintutils.drawFilledBox(1, y, w, y, UI.primary)
                term.setCursorPos(2, y)
                term.setTextColor(UI.background)
            elseif isInstalled then
                term.setCursorPos(2, y)
                term.setTextColor(UI.success)
            else
                term.setCursorPos(2, y)
                term.setTextColor(UI.text)
            end

            local marker = isInstalled and "* " or "  "
            local line   = marker .. entry.date .. "  v" .. entry.version .. "  " .. entry.msg
            if #line > w - 2 then line = line:sub(1, w - 2) end
            term.write(line)
        end
    end

    if histScroll > 0 then
        term.setCursorPos(w - 5, HIST_START)
        term.setBackgroundColor(UI.background)
        term.setTextColor(UI.subtext)
        term.write("[^ up]")
    end
    if histEntries and histScroll + HIST_VIS < #histEntries then
        term.setCursorPos(w - 7, HIST_END)
        term.setBackgroundColor(UI.background)
        term.setTextColor(UI.subtext)
        term.write("[v more]")
    end

    paintutils.drawFilledBox(1, h - 2, w, h - 2, UI.border)

    -- Install button grayed out if files.json unavailable
    local canInstall = (histSelected ~= nil and filesOk)
    local ix = math.floor((w - #HIST_INSTALL) / 2)
    paintutils.drawFilledBox(ix, h - 1, ix + #HIST_INSTALL - 1, h - 1,
        canInstall and UI.primary or UI.border)
    term.setCursorPos(ix, h - 1)
    term.setTextColor(canInstall and UI.background or UI.subtext)
    term.write(HIST_INSTALL)

    term.setCursorPos(2, h)
    term.setBackgroundColor(UI.background)
    term.setTextColor(UI.subtext)
    if not filesOk then
        term.write("files.json unavailable — installs disabled")
    else
        term.write("Up/Down or click to select  |  Enter to install  |  * = installed")
    end
end

-- ---- doUpdate ---------------------------------------------------------------

local function doUpdate(targetSHA, isRollback)
    clearBody()
    status(4, isRollback and "Rolling back..." or "Downloading updates...", UI.primary)

    local toDownload     = {}
    local toDelete       = {}
    local rawBase        = REPO_RAW .. targetSHA .. "/"
    local updaterSkipped = false

    -- Helper: filter .updater out of any file list
    local function filterUpdater(list)
        local out = {}
        for _, pair in ipairs(list) do
            if pair[2] == UPDATER_LOCAL_PATH then
                updaterSkipped = true
            else
                table.insert(out, pair)
            end
        end
        return out
    end

    if isRollback then
        status(5, "Fetching file list at target version...", UI.subtext)
        local snapFilesBody = httpGet(rawBase .. "files.json")
        if not snapFilesBody then
            status(5, "Could not fetch files.json at target SHA.", UI.error)
            sleep(2)
            -- Redraw so we land back on the history tab cleanly
            term.setBackgroundColor(UI.background)
            term.clear()
            drawHeader()
            tabBounds = drawTabs(activeTab)
            drawHistoryTab()
            return
        end

        -- .updater is always excluded — even on rollback
        toDownload = filterUpdater(parseFiles(snapFilesBody))

        local snapMap = parseFilesAsMap(snapFilesBody)
        local curMap  = parseFilesAsMap(filesBody)
        for repoPath, localPath in pairs(curMap) do
            if not snapMap[repoPath] and localPath ~= UPDATER_LOCAL_PATH then
                table.insert(toDelete, localPath)
            end
        end

    elseif localSHA == nil then
        toDownload = filterUpdater(FILES)
        rawBase    = RAW_MAIN

    else
        rawBase = RAW_MAIN
        status(5, "Fetching diff...", UI.subtext)
        local compareBody = httpGet(API_COMPARE .. localSHA .. "..." .. targetSHA)

        if not compareBody then
            status(5, "Diff fetch failed. Falling back to full install.", UI.error)
            sleep(1.5)
            toDownload = filterUpdater(FILES)
        else
            local ok2, compareData = pcall(textutils.unserialiseJSON, compareBody)
            if not ok2 or not compareData or not compareData.files then
                status(5, "Diff parse failed. Falling back to full install.", UI.error)
                sleep(1.5)
                toDownload = filterUpdater(FILES)
            else
                local fileMap    = parseFilesAsMap(filesBody)
                local oldFileMap = {}
                if fs.exists(LOCAL_CACHE) then
                    local cf = fs.open(LOCAL_CACHE, "r")
                    oldFileMap = parseFilesAsMap(cf.readAll())
                    cf.close()
                end

                for _, fileEntry in ipairs(compareData.files) do
                    local repoPath = fileEntry.filename
                    local st       = fileEntry.status

                    if st == "removed" then
                        local lp = oldFileMap[repoPath]
                        if lp and lp ~= UPDATER_LOCAL_PATH then
                            table.insert(toDelete, lp)
                        end

                    elseif st == "added" or st == "modified" then
                        local lp = fileMap[repoPath]
                        if lp then
                            if lp == UPDATER_LOCAL_PATH then
                                updaterSkipped = true
                            else
                                table.insert(toDownload, { repoPath, lp })
                            end
                        end

                    elseif st == "renamed" then
                        if fileEntry.previous_filename then
                            local oldLp = oldFileMap[fileEntry.previous_filename]
                            if oldLp and oldLp ~= UPDATER_LOCAL_PATH then
                                table.insert(toDelete, oldLp)
                            end
                        end
                        local lp = fileMap[repoPath]
                        if lp then
                            if lp == UPDATER_LOCAL_PATH then
                                updaterSkipped = true
                            else
                                table.insert(toDownload, { repoPath, lp })
                            end
                        end
                    end
                end

                if #toDownload == 0 and #toDelete == 0 and not updaterSkipped then
                    saveLocalSHA(targetSHA)
                    saveLocalVersion(remoteVersion)
                    local fc = fs.open(LOCAL_CACHE, "w")
                    fc.write(filesBody); fc.close()
                    status(5, "No OS files changed. Version record updated.", UI.success)
                    sleep(2); os.reboot(); return
                end
            end
        end
    end

    -- ---- Execute deletions and downloads ------------------------------------

    local totalOps    = math.max(#toDelete + #toDownload, 1)
    local opsDone     = 0
    local barW        = w - 4
    local barX        = 3
    local barY        = 6
    local logY        = 8
    local needsReboot = false

    local function updateBar()
        local filled = math.floor(barW * (opsDone / totalOps))
        if filled > 0 then
            paintutils.drawFilledBox(barX, barY, barX + filled - 1, barY, UI.primary)
        end
        paintutils.drawFilledBox(barX + filled, barY, barX + barW - 1, barY, UI.border)
        local pct = math.floor(100 * opsDone / totalOps) .. "%"
        term.setCursorPos(math.floor((w - #pct) / 2), barY - 1)
        term.setBackgroundColor(UI.background)
        term.setTextColor(UI.primary)
        term.write(pct)
    end

    paintutils.drawFilledBox(barX, barY, barX + barW - 1, barY, UI.border)
    updateBar()

    for _, localPath in ipairs(toDelete) do
        status(logY, "Removing " .. localPath .. "...", UI.subtext)
        if fs.exists(localPath) then
            fs.delete(localPath)
            status(logY, "[-] Removed: " .. localPath, UI.error)
        end
        opsDone = opsDone + 1; updateBar(); sleep(0.05)
    end

    for _, pair in ipairs(toDownload) do
        local repoPath, localPath = pair[1], pair[2]
        status(logY, "Downloading " .. repoPath .. "...", UI.subtext)

        local isBinary = localPath:sub(-6) == ".dfpwm"
        local body = isBinary and httpGetBinary(rawBase .. repoPath)
                               or httpGet(rawBase .. repoPath)

        if body then
            local dir = fs.getDir(localPath)
            if dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
            local writePath = localPath
            if localPath == "/startup.lua" then
                writePath = "/.startup_update"
                needsReboot = true
            end
            local f = fs.open(writePath, isBinary and "wb" or "w")
            if f then
                f.write(body); f.close()
                status(logY, "[+] " .. repoPath, UI.success)
            else
                status(logY, "[!] " .. repoPath .. " (open failed)", UI.error)
            end
        else
            status(logY, "[!] " .. repoPath .. " (download failed)", UI.error)
        end
        opsDone = opsDone + 1; updateBar(); sleep(0.05)
    end

    if needsReboot then
        local shim = fs.open("/startup.lua", "w")
        shim.write(
            '-- PunOS update shim\n' ..
            'if fs.exists("/.startup_update") then\n' ..
            '  fs.delete("/startup.lua")\n' ..
            '  fs.move("/.startup_update", "/startup.lua")\n' ..
            'end\n' ..
            'shell.run("/startup.lua")\n'
        )
        shim.close()
    end

    saveLocalSHA(targetSHA)
    if isRollback then
        local snapVer = httpGet(rawBase .. "version.json")
        if snapVer then
            local v = jsonStr(snapVer, "version")
            if v then saveLocalVersion(v) end
        end
        local snapCache = httpGet(rawBase .. "files.json")
        if snapCache then
            local fc = fs.open(LOCAL_CACHE, "w")
            fc.write(snapCache); fc.close()
        end
    else
        saveLocalVersion(remoteVersion)
        local fc = fs.open(LOCAL_CACHE, "w")
        fc.write(filesBody); fc.close()
    end

    status(logY, "All done!", UI.success)

    if updaterSkipped then
        status(logY + 1, "Note: .updater was changed in this release.", UI.primary)
        status(logY + 2, "Run the installer to update it.", UI.subtext)
        sleep(4)
    elseif needsReboot then
        status(logY + 1, "startup.lua will apply on reboot.", UI.subtext)
        sleep(1)
    end

    for i = 3, 1, -1 do
        term.setCursorPos(2, h)
        term.setBackgroundColor(UI.background)
        term.setTextColor(UI.subtext)
        term.clearLine()
        term.write("Rebooting in " .. i .. "...")
        sleep(1)
    end
    os.reboot()
end

-- ---- Rollback confirm -------------------------------------------------------
-- Always shown before any rollback. Includes an extra warning line if
-- .updater differs at the target SHA (informational only — .updater is
-- never replaced regardless).

local function confirmRollback(entry)
    local remoteUpdater    = httpGet(REPO_RAW .. entry.sha .. "/os/.updater")
    local localUpdaterFile = fs.open(UPDATER_LOCAL_PATH, "r")
    local localUpdater     = localUpdaterFile and localUpdaterFile.readAll() or ""
    if localUpdaterFile then localUpdaterFile.close() end
    local updaterDiffers   = (remoteUpdater ~= nil and remoteUpdater ~= localUpdater)

    local lines = {
        "  Roll back to v" .. entry.version .. "?  ",
        "",
        "This will replace your current OS files with",
        "the files from that version.",
    }

    if updaterDiffers then
        table.insert(lines, "")
        table.insert(lines, "Note: that version had a different .updater.")
        table.insert(lines, "Yours will NOT be changed, but if it is")
        table.insert(lines, "incompatible you may need a fresh install.")
    end

    table.insert(lines, "")
    table.insert(lines, "This cannot be undone without updating again.")

    return confirmDialog(lines, " Yes, roll back ", " Cancel ")
end

-- ---- Initial draw -----------------------------------------------------------

term.setBackgroundColor(UI.background)
term.clear()
drawHeader()
tabBounds = drawTabs(activeTab)
drawUpdatesTab()

-- ---- Event loop -------------------------------------------------------------

while true do
    local e, p1, p2, p3 = os.pullEvent()

    if e == "mouse_click" then
        local mx, my = p2, p3

        if my == 3 then
            for i, bounds in ipairs(tabBounds) do
                if mx >= bounds[1] and mx <= bounds[2] and i ~= activeTab then
                    activeTab = i
                    tabBounds = drawTabs(activeTab)
                    if activeTab == 1 then
                        drawUpdatesTab()
                    else
                        histSelected = nil
                        drawHistoryTab()
                    end
                end
            end

        elseif activeTab == 1 then
            if my == h - 1 then
                if filesOk and mx >= ux and mx <= ux + #updateLabel - 1 then
                    doUpdate(latestSHA, false); return
                elseif mx >= bx and mx <= bx + #backLabel - 1 then
                    break
                end
            end

        elseif activeTab == 2 then
            if my >= HIST_START and my <= HIST_END then
                local idx = my - HIST_START + 1 + histScroll
                if histEntries and histEntries[idx] then
                    histSelected = idx
                    drawHistoryTab()
                end
            elseif my == h - 1 and histSelected and filesOk then
                local ix = math.floor((w - #HIST_INSTALL) / 2)
                if mx >= ix and mx <= ix + #HIST_INSTALL - 1 then
                    local entry = histEntries[histSelected]
                    if entry then
                        local confirmed = confirmRollback(entry)
                        if confirmed then doUpdate(entry.sha, true); return end
                        -- Redraw after dialog regardless
                        term.setBackgroundColor(UI.background)
                        term.clear()
                        drawHeader()
                        tabBounds = drawTabs(activeTab)
                        drawHistoryTab()
                    end
                end
            end
        end

    elseif e == "mouse_scroll" then
        if activeTab == 1 then
            if p1 == 1 and scrollOff + visLines < #noteLines then
                scrollOff = scrollOff + 1; drawNotes()
            elseif p1 == -1 and scrollOff > 0 then
                scrollOff = scrollOff - 1; drawNotes()
            end
        elseif activeTab == 2 and histEntries then
            if p1 == 1 and histScroll + HIST_VIS < #histEntries then
                histScroll = histScroll + 1; drawHistoryTab()
            elseif p1 == -1 and histScroll > 0 then
                histScroll = histScroll - 1; drawHistoryTab()
            end
        end

    elseif e == "key" then
        if p1 == keys.backspace then
            if activeTab == 2 then
                activeTab = 1
                tabBounds = drawTabs(activeTab)
                drawUpdatesTab()
            else
                break
            end

        elseif activeTab == 1 then
            if p1 == keys.up and scrollOff > 0 then
                scrollOff = scrollOff - 1; drawNotes()
            elseif p1 == keys.down and scrollOff + visLines < #noteLines then
                scrollOff = scrollOff + 1; drawNotes()
            elseif p1 == keys.enter and filesOk then
                doUpdate(latestSHA, false); return
            end

        elseif activeTab == 2 and histEntries then
            if p1 == keys.up then
                if histSelected and histSelected > 1 then
                    histSelected = histSelected - 1
                    if histSelected <= histScroll then histScroll = histSelected - 1 end
                    drawHistoryTab()
                elseif not histSelected and #histEntries > 0 then
                    histSelected = 1; drawHistoryTab()
                end
            elseif p1 == keys.down then
                if histSelected and histSelected < #histEntries then
                    histSelected = histSelected + 1
                    if histSelected > histScroll + HIST_VIS then
                        histScroll = histSelected - HIST_VIS
                    end
                    drawHistoryTab()
                elseif not histSelected and #histEntries > 0 then
                    histSelected = 1; drawHistoryTab()
                end
            elseif p1 == keys.enter and histSelected and filesOk then
                local entry = histEntries[histSelected]
                if entry then
                    local confirmed = confirmRollback(entry)
                    if confirmed then doUpdate(entry.sha, true); return end
                    term.setBackgroundColor(UI.background)
                    term.clear()
                    drawHeader()
                    tabBounds = drawTabs(activeTab)
                    drawHistoryTab()
                end
            end
        end
    end
end

term.setBackgroundColor(colors.black)
term.clear()
term.setCursorPos(1, 1)
shell.run(".menu")
