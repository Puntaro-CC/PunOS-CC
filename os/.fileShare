os.pullEvent = os.pullEventRaw

local w, h = term.getSize()

local UI = dofile("/os/loadTheme.lua")

function printCentered(y, s, color)
    color = color or UI.text
    local x = math.floor((w - string.len(s)) / 2)
    term.setCursorPos(x, y)
    term.setTextColor(color)
    term.write(s)
end

local function drawHeader()
    paintutils.drawFilledBox(1, 1, w, 2, UI.border)
    term.setCursorPos(2, 1)
    term.setTextColor(UI.primary)
    term.write("PunOS")
    term.setCursorPos(2, 2)
    term.setTextColor(UI.subtext)
    term.write("File Sharing")
end

local options = {
    {name = "Upload File",   icon = "^", desc = "Send files to network"},
    {name = "Download File", icon = "v", desc = "Get files from network"},
    {name = "Back",          icon = "<", desc = "Return to programs"}
}

local nOption = 1
local buttonRegions = {}
local boxWidth = 22
local boxHeight = 3

local function drawMenu()
    term.setBackgroundColor(UI.background)
    term.clear()
    drawHeader()

    printCentered(4, "FILE SHARING", UI.primary)
    printCentered(5, "Network File Transfer", UI.subtext)

    local startY = 7

    buttonRegions = {}

    for i, option in ipairs(options) do
        local y = startY + (i - 1) * (boxHeight + 1)
        local x = math.floor((w - boxWidth) / 2)

        buttonRegions[i] = {x1 = x, y1 = y, x2 = x + boxWidth - 1, y2 = y + boxHeight - 1}

        if i == nOption then
            paintutils.drawFilledBox(x, y, x + boxWidth - 1, y + boxHeight - 1, UI.primary)
            term.setTextColor(UI.background)
        else
            paintutils.drawFilledBox(x, y, x + boxWidth - 1, y + boxHeight - 1, UI.border)
            term.setTextColor(UI.text)
        end

        term.setCursorPos(x + 1, y + 1)
        term.write("[" .. option.icon .. "] " .. option.name)

        term.setTextColor(UI.subtext)
        term.setCursorPos(x + 1, y + 2)
        term.write(option.desc)
    end

    term.setCursorPos(2, h)
    term.setTextColor(UI.subtext)
    term.write("W/S or Click: Select | Enter: Confirm")
end

drawMenu()

while true do
    local e, p, p2, p3 = os.pullEvent()

    if e == "key" then
        if p == keys.w or p == keys.up then
            if nOption > 1 then
                nOption = nOption - 1
                drawMenu()
            end
        elseif p == keys.s or p == keys.down then
            if nOption < #options then
                nOption = nOption + 1
                drawMenu()
            end
        elseif p == keys.enter then
            break
        end

    elseif e == "mouse_click" then
        local mx, my = p2, p3
        local clicked = false
        for i, r in ipairs(buttonRegions) do
            if mx >= r.x1 and mx <= r.x2 and my >= r.y1 and my <= r.y2 then
                nOption = i
                clicked = true
                break
            end
        end
        if clicked then
            drawMenu()
            sleep(0.08)
            break
        end
    end
end

term.setBackgroundColor(colors.black)
term.clear()

if nOption == 1 then
    shell.run("os/.upload")
elseif nOption == 2 then
    shell.run("os/.download")
else
    shell.run("os/.programs")
end