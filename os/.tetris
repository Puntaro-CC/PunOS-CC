-- PunOS Tetris
-- Based on original by dzanis 12.07.12
-- Restyled for PunOS

os.pullEvent = os.pullEventRaw

local w, h = term.getSize()

local UI = dofile("/os/loadTheme.lua")
UI.block = UI.primary  -- block color follows theme

local sX = math.floor(w / 2 - 10 / 2)
local sY = 3
local iX = 2
local iY = 4

local matrix = {}
for p = 1, 150 do  -- Changed from 200 to 150 (10 width  15 height)
    matrix[p] = 0 
end

local figurePosX = 4
local figurePosY = 1
local figureNum = 1
local figureNextNum = math.random(1, 7)
local figureRotateNumber = 1

local figure = {
    {{0,0,1,0,0,1,1,1}},
    {{0,1,1,1,2,1,1,2},{1,0,0,1,1,1,1,2},{1,0,0,1,1,1,2,1},{1,0,1,1,2,1,1,2}},
    {{1,0,1,1,1,2,2,2},{0,1,1,1,2,1,0,2},{0,0,1,0,1,1,1,2},{2,0,0,1,1,1,2,1}},
    {{1,0,1,1,1,2,0,2},{0,0,0,1,1,1,2,1},{1,0,2,0,1,1,1,2},{0,1,1,1,2,1,2,2}},
    {{0,1,1,1,1,2,2,2},{1,0,0,1,1,1,0,2}},
    {{1,1,2,1,0,2,1,2},{0,0,0,1,1,1,1,2}},
    {{0,2,1,2,2,2,3,2},{1,0,1,1,1,2,1,3}}
}

local run = true
local FIRST = 1
local PAUSE = 2
local GAME_OVER = 3
local GAME = 4
local gameState = FIRST
local speed = 1.0
local SCORE = 0
local LINES = 0
local LEVEL = 0

-- Draw PunOS header
local function drawHeader()
    paintutils.drawFilledBox(1, 1, w, 2, UI.border)
    term.setCursorPos(2, 1)
    term.setTextColor(UI.primary)
    term.write("PunOS")
    term.setCursorPos(2, 2)
    term.setTextColor(UI.subtext)
    term.write("Tetris")
end

-- Draw game info
local function paintInfo()
    y = iY
    
    term.setBackgroundColor(UI.background)
    term.setTextColor(UI.primary)
    term.setCursorPos(iX, y)
    term.write("SCORE")
    term.setTextColor(UI.text)
    term.setCursorPos(iX, y + 1)
    term.write(SCORE)
    
    y = y + 3
    term.setTextColor(UI.primary)
    term.setCursorPos(iX, y)
    term.write("LINES")
    term.setTextColor(UI.text)
    term.setCursorPos(iX, y + 1)
    term.write(LINES)
    
    y = y + 3
    term.setTextColor(UI.primary)
    term.setCursorPos(iX, y)
    term.write("LEVEL")
    term.setTextColor(UI.text)
    term.setCursorPos(iX, y + 1)
    term.write(LEVEL)
    
    -- Next piece preview
    y = y + 3
    term.setTextColor(UI.primary)
    term.setCursorPos(iX, y)
    term.write("NEXT")
    
    -- Draw next piece preview box
    paintutils.drawBox(iX, y + 1, iX + 5, y + 4, UI.border)
    
    for i = 1, 8, 2 do 
        local px = iX + 1 + figure[figureNextNum][1][i]
        local py = y + 2 + figure[figureNextNum][1][i + 1]
        term.setCursorPos(px, py)
        term.setTextColor(UI.block)
        term.write("@")
    end
end

-- Draw controls help
local function paintHelp()
    local y = iY
    local x = sX + 14
    
    local helpText = {
        "CONTROLS",
        "",
        "Move: A/D",
        "or <- ->",
        "",
        "Rotate:",
        "Space",
        "",
        "Drop: S",
        "or Down",
        "",
        "Pause: P",
        "",
        "Exit:",
        "Backspace"
    }
    
    term.setBackgroundColor(UI.background)
    for i = 1, #helpText do
        term.setCursorPos(x, y + i - 1)
        if i == 1 then
            term.setTextColor(UI.primary)
        else
            term.setTextColor(UI.subtext)
        end
        term.write(helpText[i])
    end
end

-- Draw the game matrix
local function paintMatrix()
    -- Draw playing field border
    paintutils.drawBox(sX - 1, sY - 1, sX + 10, sY + 15, UI.border)
    
    -- Draw background
    for y = 0, 14 do
        term.setCursorPos(sX, sY + y)
        term.setBackgroundColor(UI.background)
        term.setTextColor(UI.subtext)
        term.write("..........")
    end

    local pos = 1  -- Changed from 21 to 1 - start from beginning of matrix
    
    -- Draw matrix with blocks (show 15 rows)
    for y = sY, sY + 14 do
        for x = sX, sX + 9 do
            if matrix[pos] ~= 0 then
                term.setCursorPos(x, y)
                term.setTextColor(UI.block)
                term.write("@")
            end
            if matrix[pos] == -1 then 
                matrix[pos] = 0 
            end
            pos = pos + 1
        end
    end
end

-- Check if figure can move
local function canMove()
    for i = 1, 8, 2 do 
        x = figurePosX + figure[figureNum][figureRotateNumber][i]
        y = figurePosY + (figure[figureNum][figureRotateNumber][i + 1] * 10)
        if x < 0 or x > 9 or x + y > 150 or x + y < 1 then  -- Changed 200 to 150
            return false
        end
        if matrix[x + y] == 1 then
            return false
        end
    end
    return true
end

local function newFigure()
    figurePosX = 4
    figurePosY = 1
    figureRotateNumber = 1
    figureNum = figureNextNum
    figureNextNum = math.random(1, 7)
    return 
end

-- Insert figure into matrix
local function insertFigureToMatrix() 
    local kube, pos, linesCount, count, len = 0
    if canMove() then  
        kube = -1
    else
        figurePosY = figurePosY - 10
        kube = 1
    end
    
    -- Write figure to matrix
    for i = 1, 8, 2 do  
        pos = figurePosX + figure[figureNum][figureRotateNumber][i] + figurePosY + (figure[figureNum][figureRotateNumber][i + 1] * 10)
        matrix[pos] = kube
    end
    
    pos = 1  -- Changed from 21 to 1
    linesCount = 0
    
    -- Check for complete lines (15 rows)
    for y = 1, 15 do
        count = 0
        for x = 1, 10 do
            if matrix[pos] == 1 then
                count = count + 1
            end
            if y == 1 and count > 0 then
                gameState = GAME_OVER
            end
            if count == 10 then  
                linesCount = linesCount + 1 
                len = pos
                while len > 11 do  -- Changed from 31 to 11
                    for i = len, len - 10, -1 do  
                        matrix[i] = matrix[i - 10] 
                    end
                    len = len - 10
                end
                paintMatrix()
                sleep(0.1)
            end
            pos = pos + 1
        end
    end
    
    -- Update score and level
    if linesCount > 0 then 
        LINES = LINES + linesCount
        LEVEL = math.floor(LINES / 10)
        local bonus = {10, 50, 100, 200}
        SCORE = SCORE + bonus[linesCount]
    end
     
    if kube == 1 then
        newFigure()
    end
    return
end

local timer = os.startTimer(0)
local event, p1, p2 = nil

local function game()
    previosRotateNumber = figureRotateNumber
    previosPosX = figurePosX
    previosPosY = figurePosY
    
    if event == "key" then
        local key = p1
        if key == keys.left or key == keys.a then
            figurePosX = figurePosX - 1
        elseif key == keys.right or key == keys.d then
            figurePosX = figurePosX + 1
        elseif key == keys.enter or key == keys.space then
            figureRotateNumber = ((#figure[figureNum] > figureRotateNumber) and figureRotateNumber + 1) or 1
        elseif key == keys.down or key == keys.s then
            figurePosY = figurePosY + 10
        end
    end
    
    if canMove() ~= true then
        figureRotateNumber = previosRotateNumber 
        figurePosX = previosPosX
        figurePosY = previosPosY
    end
    
    speed = ((speed > 0.1) and 1.0 - LEVEL / 10) or 0.1
    
    if event == "timer" and p1 == timer then
        timer = os.startTimer(speed)
        figurePosY = figurePosY + 10
    end
    return
end

-- New game
local function newGame()
    SCORE = 0 
    LINES = 0 
    LEVEL = 0
    for p = 1, 150 do  -- Changed from 200 to 150
        matrix[p] = 0  
    end
    newFigure()
    return
end

-- Dialog for game states
flashing = true
local function paintDialog()
    local text = {
        {" WELCOME TO TETRIS",
         "     P A U S E",
         "  G A M E  O V E R",
         "   PLAY TETRIS"},
        {"   Press any key",
         "   Press any key",
         "   Press any key",
         ""}
    }
    
    if gameState ~= GAME then
        -- Draw dialog box
        local boxW = 22
        local boxH = 6
        local boxX = math.floor(w / 2 - boxW / 2)
        local boxY = math.floor(h / 2 - boxH / 2)
        
        paintutils.drawFilledBox(boxX, boxY, boxX + boxW, boxY + boxH, UI.border)
        paintutils.drawFilledBox(boxX + 1, boxY + 1, boxX + boxW - 1, boxY + boxH - 1, UI.background)
        
        term.setCursorPos(boxX + 2, boxY + 2)
        term.setTextColor(UI.primary)
        term.write(text[1][gameState])
        
        if flashing then
            term.setCursorPos(boxX + 2, boxY + 4)
            term.setTextColor(UI.subtext)
            term.write(text[2][gameState])
        end
    end
    
    if event == "timer" and p1 == timer then
        timer = os.startTimer(0.5)
        flashing = flashing ~= true
    end
    return
end

-- Start game
newGame()

while run do
    event, p1, p2 = os.pullEvent()
    
    if event == "key" then
        local key = p1
        if key == keys.p then
            gameState = PAUSE
        elseif key == keys.backspace then
            -- Proper exit handling
            term.setBackgroundColor(colors.black)
            term.clear()
            term.setCursorPos(1, 1)
            shell.run("os/.programs")
            return
        elseif key > 1 and gameState ~= GAME then
            if gameState == GAME_OVER then 
                newGame()  
            end 
            gameState = GAME 
            timer = os.startTimer(0)
        end
    end
    
    if gameState == GAME then  
        game()
    end

    insertFigureToMatrix() 
    term.setBackgroundColor(UI.background)
    term.clear()
    drawHeader()
    paintMatrix()
    paintInfo()
    paintHelp()
    paintDialog()
end

-- This should never be reached, but just in case
term.setBackgroundColor(colors.black)
term.clear()
term.setCursorPos(1, 1)
shell.run("os/.programs")